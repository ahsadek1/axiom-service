#!/usr/bin/env python3
"""
vector_liveness_ping.py — Agent Liveness Verification (Block 7)
================================================================
Prevention spec: HTTP 200 ≠ agent is alive and processing.
This script verifies actual agent responsiveness via sessions_send,
not just HTTP port health.

Runs every 30 minutes during market hours via LaunchAgent.

Agent sessions monitored:
  - agent:sovereign:main
  - agent:genesis:telegram:group:-1003579956463
  - agent:omni:main (if exists)

Ack timeout: 60s during market hours, 300s outside.

Author: VECTOR 🔧 | Block 7 — RESILIENCE_SPEC_v2.0 | May 1, 2026
"""

import json
import logging
import os
import subprocess
import sys
import time
from datetime import datetime, timezone
from zoneinfo import ZoneInfo

import requests

# ---------------------------------------------------------------------------
# Config
# ---------------------------------------------------------------------------
ET = ZoneInfo("America/New_York")
TELEGRAM_BOT_TOKEN = os.environ.get(
    "TELEGRAM_BOT_TOKEN", "8736004775:AAG3v_7tcXk8SXh5whgpKRT3Dr3-C71VtQI"
)
AHMED_TELEGRAM_ID = "8573754783"
GROUP_CHAT_ID = "-1003579956463"
MESSAGE_BUS = "http://192.168.1.141:9999"
CHRONICLE_DB = "/Users/ahmedsadek/nexus/data/chronicle.db"

# Agent sessions to verify — (label, bus_name, critical)
# bus_name = the agent's name on the message bus (used for inbox/send)
# critical=True → alert Ahmed directly on failure
AGENT_SESSIONS = [
    ("SOVEREIGN", "sovereign", True),
    ("GENESIS",   "genesis",   False),
    ("OMNI",      "omni",      True),
]

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] vector.liveness: %(message)s",
)
log = logging.getLogger("vector.liveness")


# ---------------------------------------------------------------------------
# Market hours
# ---------------------------------------------------------------------------

def _is_market_hours() -> bool:
    """True during trading hours 9:25 AM – 4:05 PM ET, Mon–Fri."""
    now = datetime.now(ET)
    if now.weekday() >= 5:
        return False
    market_open  = now.replace(hour=9, minute=25, second=0, microsecond=0)
    market_close = now.replace(hour=16, minute=5, second=0, microsecond=0)
    return market_open <= now <= market_close


def _ack_timeout_s() -> int:
    """60s during market hours, 300s outside."""
    return 60 if _is_market_hours() else 300


# ---------------------------------------------------------------------------
# Telegram alert
# ---------------------------------------------------------------------------

def _send_telegram(message: str, target: str = GROUP_CHAT_ID) -> None:
    """Send Telegram alert. Never raises."""
    try:
        requests.post(
            f"https://api.telegram.org/bot{TELEGRAM_BOT_TOKEN}/sendMessage",
            json={"chat_id": target, "text": message, "parse_mode": "Markdown"},
            timeout=10,
        )
    except Exception as e:
        log.warning("Telegram send failed: %s", e)


# ---------------------------------------------------------------------------
# Message bus notify
# ---------------------------------------------------------------------------

def _notify_sovereign(message: str) -> None:
    """Push alert to SOVEREIGN via message bus. Never raises."""
    try:
        requests.post(
            f"{MESSAGE_BUS}/send",
            json={"from": "vector", "to": "sovereign", "message": message},
            timeout=5,
        )
    except Exception as e:
        log.warning("Message bus notify failed: %s", e)


# ---------------------------------------------------------------------------
# CHRONICLE log
# ---------------------------------------------------------------------------

def _log_to_chronicle(agent: str, status: str, detail: str) -> None:
    """Log liveness result to CHRONICLE intervention_log. Never raises."""
    try:
        import sqlite3
        from datetime import datetime, timezone
        now = datetime.now(timezone.utc).isoformat()
        conn = sqlite3.connect(CHRONICLE_DB, timeout=5)
        conn.execute("""
            INSERT INTO intervention_log
            (agent, error_description, time_identified, ideal_response_time,
             time_acted, time_resolved, resolution_type, damage_assessment, outcome, notes, created_at)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        """, (
            "vector",
            f"Liveness check: {agent} → {status}",
            now, now, now,
            now if status == "alive" else None,
            "root_cause" if status == "dead" else "symptomatic",
            "none" if status == "alive" else "agent_session_unresponsive",
            "solved" if status == "alive" else "in_progress",
            detail,
            now,
        ))
        conn.commit()
        conn.close()
    except Exception as e:
        log.warning("CHRONICLE log failed: %s", e)


# ---------------------------------------------------------------------------
# Liveness check via openclaw sessions_send CLI
# ---------------------------------------------------------------------------

def _ping_agent(label: str, bus_name: str) -> tuple[bool, str]:
    """
    Send a LIVENESS_PING via the message bus and wait for an ack in the
    vector inbox. Returns (alive: bool, detail: str).

    Protocol:
      1. Send ping message to agent via bus
      2. Wait up to ack_timeout_s
      3. Poll vector inbox for a response from that agent
      4. If ack found within timeout → alive. Else → dead.
    """
    timeout_s = _ack_timeout_s()
    ping_id = f"ping-{int(time.time())}"
    ping_msg = f"LIVENESS_PING:{ping_id} from VECTOR — {datetime.now(ET).strftime('%H:%M ET')}. Ack with PONG:{ping_id}."

    log.info("Pinging %s via bus — timeout %ds", label, timeout_s)

    try:
        # Send ping
        r = requests.post(
            f"{MESSAGE_BUS}/send",
            json={"from": "vector", "to": bus_name, "message": ping_msg},
            timeout=5,
        )
        if not r.ok:
            return False, f"bus send failed: HTTP {r.status_code}"
    except Exception as e:
        return False, f"bus send error: {e}"

    # Poll vector inbox for ack
    deadline = time.time() + timeout_s
    poll_interval = 5  # seconds
    while time.time() < deadline:
        time.sleep(poll_interval)
        try:
            inbox = requests.get(f"{MESSAGE_BUS}/inbox/vector", timeout=5)
            if inbox.ok:
                messages = inbox.json().get("messages", [])
                for msg in messages:
                    if (msg.get("from") == bus_name and
                            ping_id in msg.get("message", "")):
                        return True, f"ack received in {int(time.time() - (deadline - timeout_s))}s"
        except Exception as e:
            log.warning("Inbox poll error: %s", e)

    # Timeout — but check: is the agent sending ANY recent heartbeat to SOVEREIGN?
    # If yes, agent is alive but not configured to respond to pings — treat as alive.
    try:
        sovereign_inbox = requests.get(f"{MESSAGE_BUS}/inbox/sovereign", timeout=5)
        if sovereign_inbox.ok:
            messages = sovereign_inbox.json().get("messages", [])
            recent_cutoff = time.time() - timeout_s - 60  # within ping window
            for msg in messages:
                if msg.get("from") == bus_name:
                    # Agent is alive and talking to SOVEREIGN
                    ts_str = msg.get("timestamp", "")
                    try:
                        from datetime import datetime as _dt
                        msg_ts = _dt.fromisoformat(ts_str.replace("Z", "+00:00")).timestamp()
                        if msg_ts > recent_cutoff:
                            log.info("%s: no ping ack but recent heartbeat found — treating as alive", label)
                            return True, f"no ping ack but recent heartbeat at {ts_str[:19]}"
                    except Exception:
                        pass
    except Exception as e:
        log.warning("Sovereign inbox check failed: %s", e)

    return False, f"no response within {timeout_s}s and no recent heartbeat found"


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main() -> int:
    log.info("VECTOR liveness ping starting — market_hours=%s", _is_market_hours())

    dead_agents = []

    for label, bus_name, critical in AGENT_SESSIONS:
        alive, detail = _ping_agent(label, bus_name)

        status = "alive" if alive else "dead"
        _log_to_chronicle(label, status, detail)

        if not alive:
            dead_agents.append((label, bus_name, critical, detail))
            log.warning("DEAD AGENT: %s — %s", label, detail)

    if dead_agents:
        # Build alert message
        lines = ["🔴 *VECTOR — AGENT LIVENESS ALERT*\n"]
        for label, session_key, critical, detail in dead_agents:
            severity = "🚨 CRITICAL" if critical else "⚠️ WARNING"
            lines.append(f"{severity}: `{label}` session unresponsive")
            lines.append(f"Session: `{session_key}`")
            lines.append(f"Detail: {detail}\n")

        lines.append(f"Time: {datetime.now(ET).strftime('%H:%M ET')}")
        lines.append("HTTP health may still show 200 — this is a session-level failure.")
        alert_msg = "\n".join(lines)

        # Alert group
        _send_telegram(alert_msg, GROUP_CHAT_ID)

        # Alert Ahmed directly for critical agents
        critical_dead = [a for a in dead_agents if a[2]]
        if critical_dead:
            _send_telegram(alert_msg, AHMED_TELEGRAM_ID)
            _notify_sovereign(
                f"VECTOR LIVENESS ALERT: {', '.join(a[0] for a in critical_dead)} "
                f"session(s) unresponsive. HTTP health may show OK. Manual check required."
            )

        log.error("Liveness check FAILED: %d dead agent(s)", len(dead_agents))
        return 1

    log.info("Liveness check: all agents responsive")
    return 0


if __name__ == "__main__":
    sys.exit(main())
